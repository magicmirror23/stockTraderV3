# ============================================================
# StockTrader Environment Configuration
# ============================================================

# ----- Mode -----
# Set to "false" to enable live trading via AngelOne SmartAPI
PAPER_MODE=true

# ----- AngelOne SmartAPI Credentials -----
# Sign up at https://smartapi.angelone.in/
ANGEL_API_KEY=tuI9emOo
ANGEL_CLIENT_ID=AAAE305533
ANGEL_MPIN=1437
ANGEL_TOTP_SECRET=WT6KB7AKHEREKSSJZQQK2HNC34

# ----- Database -----
DATABASE_URL=sqlite:///./stocktrader.db

# ----- Redis / Celery -----
CELERY_BROKER_URL=redis://localhost:6379/1

# ----- MLflow -----
MLFLOW_TRACKING_URI=http://localhost:5000

# ----- Market Data -----
# Refresh all symbol CSVs on service startup (first 55 symbols)
MARKET_DATA_BOOTSTRAP_DOWNLOAD=true
MARKET_DATA_BOOTSTRAP_LIMIT=0
# Scheduler auto-refreshes DB + CSVs every 4 hours (enabled by default)
# MDS_SCHEDULER_ENABLED=true
# MDS_SCHEDULER_REFRESH_MINUTES=240

# ----- News API (optional) -----
NEWS_API_KEY=

# ----- App -----
LOG_LEVEL=INFO

# ---- CORS ----
ALLOWED_ORIGINS=https://stockv3.vercel.app,http://localhost:3000,http://localhost:8000

# ----------------------------
# Global / Runtime
# ----------------------------
APP_ENV=production
LOG_LEVEL=INFO
TZ=Asia/Kolkata
ALLOWED_ORIGINS=https://your-frontend-domain.com

# ----------------------------
# Reverse Proxy (Caddy)
# ----------------------------
# Bootstrap with HTTP only on IP:
#   CADDY_SITE_ADDRESS=:80
# Enable automatic HTTPS after DNS is pointed:
#   CADDY_SITE_ADDRESS=api.yourdomain.com
CADDY_SITE_ADDRESS=:80
TLS_EMAIL=you@example.com

# ----------------------------
# Database / Cache
# ----------------------------
POSTGRES_USER=stocktrader
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=stocktrader
DATABASE_URL=postgresql+psycopg2://stocktrader:CHANGE_ME_STRONG_PASSWORD@postgres:5432/stocktrader
REDIS_URL=redis://redis:6379/0

# Optional broker (enabled only with compose profile "queue")
BROKER_URL=amqp://stocktrader:CHANGE_ME_RABBIT@rabbitmq:5672/stocktrader
RABBITMQ_USER=stocktrader
RABBITMQ_PASSWORD=CHANGE_ME_RABBIT
RABBITMQ_VHOST=stocktrader

# ----------------------------
# Internal service URLs (gateway)
# ----------------------------
MARKET_DATA_URL=http://market-data:8001
PREDICTION_URL=http://prediction:8002
TRADING_URL=http://trading:8003
RISK_URL=http://portfolio-risk:8005
ADMIN_URL=http://admin-backtest:8004

# ----------------------------
# Inference / Model runtime
# ----------------------------
INFERENCE_ONLY=true
ALLOW_PROD_RETRAIN=false
TRAIN_DATA_SOURCE_MODE=local_store_only
MODEL_REGISTRY_DIR=/opt/models
ACTIVE_MODEL_DIR=
PREDICTION_MIN_EDGE_BPS=6
PREDICTION_SLIPPAGE_BPS=2

# ----------------------------
# Security / admin
# ----------------------------
ADMIN_API_TOKEN=CHANGE_ME_ADMIN_TOKEN
MODEL_SYNC_TOKEN=CHANGE_ME_MODEL_SYNC_TOKEN
SYNC_MODEL_TO_PREDICTION=false

# ----------------------------
# Broker credentials (if live trading enabled)
# ----------------------------
ANGEL_API_KEY=
ANGEL_CLIENT_ID=
ANGEL_MPIN=
ANGEL_TOTP_SECRET=
PAPER_MODE=true

# ----------------------------
# Service worker counts / timeouts
# Keep conservative for Always Free ARM.
# ----------------------------
GATEWAY_WORKERS=1
MARKET_DATA_WORKERS=1
PREDICTION_WORKERS=1
TRADING_WORKERS=1
RISK_WORKERS=1
ADMIN_WORKERS=1
GATEWAY_TIMEOUT=90
MARKET_DATA_TIMEOUT=120
PREDICTION_TIMEOUT=120
TRADING_TIMEOUT=120
RISK_TIMEOUT=90
ADMIN_TIMEOUT=180

# Backtest execution realism
BACKTEST_MAX_TICKERS=120
BACKTEST_UNIVERSE_VERSION=universe_v2

# ----------------------------
# Market data scheduler (market-data service)
# ----------------------------
MARKET_DATA_BOOTSTRAP_DOWNLOAD=false
MARKET_DATA_BACKGROUND_REFRESH_ENABLED=false
MDS_SCHEDULER_ENABLED=true
MDS_SCHEDULER_REFRESH_MINUTES=240
MDS_SCHEDULER_RETRY_MINUTES=30
MDS_SCHEDULER_METADATA_MINUTES=120
MDS_DEFAULT_SYMBOLS=RELIANCE,TCS,INFY,HDFCBANK,ICICIBANK

# ----------------------------
# Postgres tuning (low resource defaults)
# ----------------------------
POSTGRES_SHARED_BUFFERS=128MB
POSTGRES_EFFECTIVE_CACHE_SIZE=512MB
POSTGRES_MAINTENANCE_WORK_MEM=64MB
POSTGRES_WORK_MEM=4MB
POSTGRES_MAX_CONNECTIONS=80

# ----------------------------
# Grafana (optional monitoring profile)
# ----------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_ADMIN
GRAFANA_ROOT_URL=http://localhost:3000


# ---- Application ----
APP_ENV=development
DEBUG=true

# ---- Database (Postgres) ----
# Leave DATABASE_URL empty to fall back to SQLite for local dev.
# In production (APP_ENV=production), DATABASE_URL MUST be set.
DATABASE_URL=postgresql://stocktrader:<CHANGE_ME>@postgres:5432/stocktrader
POSTGRES_USER=stocktrader
POSTGRES_PASSWORD=<CHANGE_ME>
POSTGRES_DB=stocktrader

# ---- Redis ----
REDIS_URL=redis://redis:6379/0

# ---- CORS ----
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ---- Secrets (do NOT commit real values) ----
SECRET_KEY=<GENERATE_RANDOM_SECRET>

# ---- Broker cache ----
ANGEL_TOKEN_CACHE_PATH=storage/runtime/angel_tokens.json

# ---- Training data download hardening ----
# Use longer lookback for feature windows (52-week + split windows).
TRAIN_DOWNLOAD_LOOKBACK_DAYS=1095
TRAIN_DOWNLOAD_EXTENDED_LOOKBACK_DAYS=1825
TRAIN_DOWNLOAD_MIN_RAW_ROWS=420
TRAIN_DOWNLOAD_TARGET_SYMBOLS=8
TRAIN_DOWNLOAD_OUTER_RETRIES=2
TRAIN_DOWNLOAD_REQUEST_PAUSE_S=1.0

# ---- Market Data Service ----
# Training/backtesting should read only local stored bars.
TRAIN_DATA_SOURCE_MODE=local_store_only
FEATURE_AUTO_HYDRATE_FROM_DB=true

# ---- Model lifecycle (offline train + inference-only serve) ----
# In production keep inference-only enabled and activate approved bundles only.
INFERENCE_ONLY=true
ALLOW_PROD_RETRAIN=false
MODEL_REGISTRY_DIR=models
ACTIVE_MODEL_DIR=
ADMIN_API_TOKEN=

# ---- Universe selection (training/backtest) ----
# universe_v1=current 52, universe_v2=curated 100, v3=150, v4=200.
UNIVERSE_VERSION=universe_v1
TRAIN_UNIVERSE_VERSION=universe_v1
BACKTEST_UNIVERSE_VERSION=universe_v1
BACKTEST_MAX_TICKERS=120
UNIVERSE_SNAPSHOT_DIR=storage/universes

# Tradability filters
UNIVERSE_MIN_MEDIAN_DAILY_VALUE=50000000
UNIVERSE_MIN_HISTORY_DAYS=180
UNIVERSE_MIN_COMPLETENESS=0.90
UNIVERSE_MAX_MISSING_RATIO=0.10
UNIVERSE_MAX_PROVIDER_FAILURES=3
UNIVERSE_MAX_STALE_DAYS=10
UNIVERSE_MAX_ZERO_VOLUME_RATIO=0.15

# Providers
TWELVE_DATA_API_KEY=
MDS_PROVIDER_MAX_RETRIES=2
MDS_BACKOFF_BASE_S=1.4
MDS_BACKOFF_JITTER_S=0.7
MDS_PROVIDER_COOLDOWN_S=180
MDS_PROVIDER_FAILURE_THRESHOLD=3
MDS_PROVIDER_FAILURE_WINDOW_S=300

# Caching & persistence
MDS_HISTORICAL_CACHE_TTL_S=90
MDS_QUOTE_CACHE_TTL_S=10
MARKET_DATA_PARQUET_ENABLED=false
MARKET_DATA_PARQUET_ROOT=storage/parquet/ohlcv

# Optional scheduler
MDS_SCHEDULER_ENABLED=true
MDS_BACKFILL_ON_START=false
MDS_SCHEDULER_REFRESH_MINUTES=240
MDS_SCHEDULER_RETRY_MINUTES=30
MDS_SCHEDULER_METADATA_MINUTES=120

# ---- Regime-aware ranking engine ----
# Use simple_classifier (default) or regime_ranking.
TRAINING_ARCHITECTURE=simple_classifier
RANKING_MODEL_MODE=classification
RANKING_HORIZON_BARS=1
RANKING_MAX_POSITIONS=8
RANKING_MIN_CONFIDENCE=0.55
RANKING_DOWNSIDE_PENALTY=0.50
RANKING_RISK_OFF_PENALTY=0.35
RANKING_ENABLE_SEQUENCE_MODEL=false


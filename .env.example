
# ---- Application ----
APP_ENV=development
DEBUG=true

# ---- Database (Postgres) ----
# Leave DATABASE_URL empty to fall back to SQLite for local dev.
DATABASE_URL=postgresql://stocktrader:stocktrader@postgres:5432/stocktrader
POSTGRES_USER=stocktrader
POSTGRES_PASSWORD=stocktrader
POSTGRES_DB=stocktrader

# ---- Redis ----
REDIS_URL=redis://redis:6379/0

# ---- CORS ----
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ---- Secrets (do NOT commit real values) ----
SECRET_KEY=change-me-in-production

# ---- Broker cache ----
ANGEL_TOKEN_CACHE_PATH=storage/runtime/angel_tokens.json



# ---- Application ----
APP_ENV=development
DEBUG=true

# ---- Database (Postgres) ----
# Leave DATABASE_URL empty to fall back to SQLite for local dev.
# In production (APP_ENV=production), DATABASE_URL MUST be set.
DATABASE_URL=postgresql://stocktrader:<CHANGE_ME>@postgres:5432/stocktrader
POSTGRES_USER=stocktrader
POSTGRES_PASSWORD=<CHANGE_ME>
POSTGRES_DB=stocktrader

# ---- Redis ----
REDIS_URL=redis://redis:6379/0

# ---- CORS ----
# For production: set to your Vercel frontend URL
# ALLOWED_ORIGINS=https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:8000

# ---- Secrets (do NOT commit real values) ----
SECRET_KEY=<GENERATE_RANDOM_SECRET>

# ---- Broker cache ----
ANGEL_TOKEN_CACHE_PATH=storage/runtime/angel_tokens.json


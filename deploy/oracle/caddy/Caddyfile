{
    email {$TLS_EMAIL}
    admin off
}

# Set CADDY_SITE_ADDRESS in .env.production.
# Examples:
#   CADDY_SITE_ADDRESS=:80                    (HTTP only, IP bootstrap)
#   CADDY_SITE_ADDRESS=api.example.com        (Auto TLS with Let's Encrypt)
#   CADDY_SITE_ADDRESS=https://api.example.com
{$CADDY_SITE_ADDRESS} {
    encode gzip zstd

    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "geolocation=(), microphone=(), camera=()"
        -Server
    }

    reverse_proxy api-gateway:8000 {
        header_up X-Forwarded-Proto {scheme}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        health_uri /api/v1/health
        health_interval 30s
        health_timeout 5s
        fail_duration 30s
    }
}

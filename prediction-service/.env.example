# Prediction Service Configuration
# Copy to .env and fill in your values

# Server
SERVICE_PORT=8010

# Database (SQLite for dev, PostgreSQL for prod)
DATABASE_URL=sqlite:///storage/prediction_service.db
DB_ECHO=false

# Redis (optional, for caching)
REDIS_URL=

# Angel One SmartAPI credentials
ANGEL_API_KEY=
ANGEL_CLIENT_ID=
ANGEL_CLIENT_PIN=
ANGEL_TOTP_SECRET=
ANGEL_TOKEN_CACHE_PATH=storage/runtime/angel_tokens.json

# Data provider: angel_one | yahoo | mock
DATA_PROVIDER=yahoo

# News API (optional)
NEWS_API_KEY=

# Model artifacts directory
MODEL_ARTIFACTS_DIR=storage/models

# Training defaults
TRAIN_LOOKBACK_DAYS=730
TRAIN_VAL_RATIO=0.15
TRAIN_TEST_RATIO=0.15
TRAIN_EMBARGO_DAYS=5
TRAIN_DEFAULT_MODEL=lightgbm

# Inference
PREDICTION_CONFIDENCE_THRESHOLD=0.55

# Monitoring
STALE_TICK_SECONDS=300
